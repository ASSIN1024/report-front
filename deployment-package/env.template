# =============================================================================
# 报表数据处理平台 - 环境变量配置
# =============================================================================
# 使用方法:
#   1. 复制此文件为 .env
#   2. 根据实际环境修改参数
#   3. 使用: source .env && ./setup.sh
# =============================================================================

# -----------------------------------------------------------------------------
# 数据库配置 (MySQL)
# -----------------------------------------------------------------------------
export DB_HOST=localhost
export DB_PORT=3306
export DB_NAME=report_db
export DB_USER=root
export DB_PASSWORD=your_password_here

# -----------------------------------------------------------------------------
# 数据库配置 (GaussDB) - 使用 GaussDB 时取消注释
# -----------------------------------------------------------------------------
# export GAUSSDB_HOST=localhost
# export GAUSSDB_PORT=5432
# export GAUSSDB_DB=report_db
# export GAUSSDB_USER=report_user
# export GAUSSDB_PASSWORD=your_password_here

# -----------------------------------------------------------------------------
# Druid 监控台账户
# -----------------------------------------------------------------------------
export DRUID_USER=admin
export DRUID_PASSWORD=admin

# -----------------------------------------------------------------------------
# 内置 FTP 服务器配置
# -----------------------------------------------------------------------------
export FTP_ENABLED=true
export FTP_PORT=9021
export FTP_USER=rpa_user
export FTP_PASSWORD=rpa_password
export FTP_ROOT=/data/ftp-root

# -----------------------------------------------------------------------------
# 日志级别 (debug/info)
# -----------------------------------------------------------------------------
export LOG_LEVEL=debug